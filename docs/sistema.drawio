      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Hardware IO -->
        <mxCell id="SYS-1" value="Hardware IO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- IOStateMonitor AO -->
        <mxCell id="SYS-2" value="&lt;b&gt;IOStateMonitor&lt;/b&gt;&lt;div&gt;&lt;i&gt;QActive&lt;/i&gt;&lt;/div&gt;&lt;div&gt;poll_ticks: uint32_t&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="155" width="170" height="80" as="geometry" />
