        <mxCell id="SYS-8" value="IO_MONITOR_POLL_SIG&lt;div&gt;(QTimeEvt)&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d6b656;curved=1;" edge="1" source="SYS-2" target="SYS-2" parent="1">
          <mxGeometry relative="1" as="geometry">
