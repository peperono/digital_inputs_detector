        <mxCell id="SYS-3" value="&lt;b&gt;DigitalEdgeDetector&lt;/b&gt;&lt;div&gt;&lt;i&gt;QActive&lt;/i&gt;&lt;/div&gt;&lt;div&gt;configs: InputConfig[]&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="155" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- Suscriptores -->
        <mxCell id="SYS-4" value="Suscriptores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="180" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Flecha: Hardware IO → IOStateMonitor (IOReader callback) -->
        <mxCell id="SYS-5" value="IOReader callback" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="SYS-1" target="SYS-2" parent="1">
          <mxGeometry relative="1" as="geometry" />
