        <!-- Flecha: IOStateMonitor → DigitalEdgeDetector (IO_STATE_CHANGED_SIG) -->
        <mxCell id="SYS-6" value="IO_STATE_CHANGED_SIG&lt;div&gt;IOStateEvt&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;" edge="1" source="SYS-2" target="SYS-3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flecha: DigitalEdgeDetector → Suscriptores (EDGE_DETECTED_SIG) -->
        <mxCell id="SYS-7" value="EDGE_DETECTED_SIG&lt;div&gt;EdgeDetectedEvt&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;" edge="1" source="SYS-3" target="SYS-4" parent="1">
          <mxGeometry relative="1" as="geometry" />
